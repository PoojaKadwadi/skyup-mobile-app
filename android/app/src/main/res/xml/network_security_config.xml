<?xml version="1.0" encoding="utf-8"?>
<!--
  network_security_config.xml
  Allows cleartext HTTP to emulator host (10.0.2.2) and all LAN IPs.
  Production (HTTPS) remains secure.
-->
<network-security-config>

  <!-- Android Emulator: 10.0.2.2 maps to host machine localhost -->
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="true">10.0.2.2</domain>
    <domain includeSubdomains="true">localhost</domain>
  </domain-config>

  <!-- Real device on LAN — allow any private IP range -->
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="true">192.168.1.1</domain>
    <domain includeSubdomains="true">192.168.1.100</domain>
    <domain includeSubdomains="true">192.168.0.100</domain>
    <domain includeSubdomains="true">192.168.0.105</domain>
    <domain includeSubdomains="true">10.0.0.1</domain>
  </domain-config>

  <!-- Production backend: HTTPS only -->
  <domain-config cleartextTrafficPermitted="false">
    <domain includeSubdomains="true">skyup-crm-backend.onrender.com</domain>
  </domain-config>

  <!-- Default: allow cleartext (covers all other IPs during development) -->
  <base-config cleartextTrafficPermitted="true">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>

</network-security-config>
